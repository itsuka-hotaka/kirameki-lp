---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = '煌めき | KIRAMEKI FARM — 信州高山村の果物農園',
  description = '長野県高山村の果物農園「煌めきファーム」。標高600mの高原で育てた、太陽と大地の恵みをたっぷり受けた旬の果物をお届けします。りんご、ぶどう、桃、さくらんぼなど四季折々の果物を栽培しています。',
} = Astro.props;

const siteUrl = 'https://kirameki-farm.pages.dev';
const ogImage = `${siteUrl}/og-image.jpg`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="煌めきファーム,KIRAMEKI FARM,高山村,果物農園,りんご,ぶどう,桃,さくらんぼ,長野県,信州" />
    <link rel="canonical" href={siteUrl} />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="KIRAMEKI FARM" />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Noto+Sans+JP:wght@300;400;500&family=Noto+Serif+JP:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>

    <!-- Global CSS -->
    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body>
    <div id="l-wrapper" style="visibility: hidden; opacity: 0;">
      <slot />
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const wrapper = document.getElementById('l-wrapper');
        if (wrapper) {
          wrapper.classList.add('is-loaded');
          wrapper.style.visibility = 'visible';
          wrapper.style.opacity = '1';
        }
      });
    </script>
  </body>
</html>

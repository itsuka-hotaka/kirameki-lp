<section class="p-hero" id="hero">
  <div class="p-hero__bg">
    <div class="p-hero__bg-img" style="background-image: url('/images/hero.webp')"></div>
  </div>
  <div class="p-hero__content">
    <div class="p-hero__logo js-blur-in">煌</div>
